{
  "appId": "com.remote-desktop.host",
  "productName": "RemoteCall-mini Host",
  "directories": {
    "buildResources": "build",
    "output": "release"
  },
  "files": [
    "dist/**"
  ],
  "extraResources": [],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "signAndEditExecutable": false
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "artifactName": "RemoteDesktopHost-Setup-${version}.exe"
  },
  "forceCodeSigning": false,
  "portable": {
    "artifactName": "RemoteDesktopHost-Portable-${version}.exe"
  },
  "npmRebuild": true,
  "asar": true,
  "asarUnpack": [
    "node_modules/@jitsi/robotjs/**"
  ]
}
